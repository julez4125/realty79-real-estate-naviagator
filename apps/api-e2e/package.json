{
  "name": "@org/api-e2e",
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  },
  "nx": {
    "name": "api-e2e",
    "implicitDependencies": [
      "api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "api:build",
          "api:serve"
        ]
      }
    },
    "tags": [
      "scope:e2e"
    ]
  }
}
