# Realty79 Environment Variables Example
# Copy to .env and fill in real values. NEVER commit .env.

# --- Database ---
DATABASE_URL="postgresql://realty79:realty79dev@localhost:5433/realty79?schema=public"

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6380

# --- LLM (Claude / Anthropic) ---
# Required from M3 onwards. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Auth ---
# Required from M0. Generate with: openssl rand -base64 48
JWT_SECRET=

# --- Optional notification channels (M1+) ---
TELEGRAM_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Mailer (M5+) ---
# Outbound SMTP — local Mailpit dev or Postfix prod
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Inbound IMAP
IMAP_HOST=localhost
IMAP_PORT=1143
IMAP_USER=
IMAP_PASS=

# --- Object Storage (M0.5+) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=realty79-documents

# --- Observability (M0+) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Scout pipeline (M2+) ---
IMMOMETRICA_USERNAME=
IMMOMETRICA_PASSWORD=

# --- Proxy (M3, optional) ---
BRIGHT_DATA_USERNAME=
BRIGHT_DATA_PASSWORD=
BRIGHT_DATA_HOST=
BRIGHT_DATA_PORT=
